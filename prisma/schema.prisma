// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 1. Model User
model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique @db.VarChar(255)
  password  String        @db.VarChar(255)
  createdAt DateTime      @default(now()) @map("created_at")
  
  // Relasi 1:M ke UserProfile
  profiles  UserProfile[]

  @@map("users") // Nama tabel di database
}

// 2. Model StandardKompetensi
model Career {
  id           String             @id @default(cuid())
  name         String             // Contoh: "Frontend Engineer", "Machine Learning Engineer"
  description  String?            @db.Text
  competencies CareerCompetency[] // Relasi Many-to-Many via Join Table
  profiles     UserProfile[]
}

model StandardKompetensi {
  id                 Int               @id @default(autoincrement())
  kodeUnit           String            @unique @map("kode_unit") @db.VarChar(100)
  judulKopetensi     String            @map("judul_kompetensi") @db.VarChar(255)
  deskripsiUnit      String?           @map("deskripsi_unit") @db.Text
  pengetahuan        Json?             // Mengacu pada Pengetahuan di SKKNI [cite: 222, 284]
  keterampilan       Json?             // Mengacu pada Keterampilan di SKKNI [cite: 227, 290]
  elemenKompetensi   Json?             @map("elemen_kompetensi") // Langkah-langkah tugas [cite: 188, 248]
  kriteriaUnjukKerja Json?             @map("kriteria_unjuk_kerja") // Detail penilaian (KUK) [cite: 188, 248]
  sumberStandar      String?           @map("sumber_standar") @db.VarChar(255) // Contoh: 'SKKNI 103/2026' [cite: 62]
  careers            CareerCompetency[]

  @@map("StandardKompetensi")
}

// Tabel Pivot untuk Many-to-Many
model CareerCompetency {
  careerId            String
  competencyId        Int
  career              Career             @relation(fields: [careerId], references: [id], onDelete: Cascade)
  competency          StandardKompetensi @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@id([careerId, competencyId])
  @@map("CareerCompetency")
}


// 3. Model UserProfile
model UserProfile {
  id                 Int      @id @default(autoincrement())
  userId             Int      @map("user_id")
  nama               String   @db.VarChar(255)
  lokasi             String?  @db.VarChar(255)
  pendidikanTerakhir String?  @map("pendidikan_terakhir") @db.VarChar(100)
  waktuBelajarJam    Int?     @map("waktu_belajar_jam")
  levelKemampuan     String?  @map("level_kemampuan") @db.VarChar(50)
  targetCareerId     String?  @map("target_career_id")

  // Definisi Relasi (Foreign Key)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetCareer       Career?           @relation(fields: [targetCareerId], references: [id], onDelete: SetNull)
  
  // Relasi balikan dari anak-anaknya (1:M)
  assessments        Assessment[]
  roadmaps           LearningRoadmap[]
  progressJRS        UserProgressJRS[]

  @@index([targetCareerId])
  @@map("user_profiles")
}

// 4. Model Assessment
model Assessment {
  id                Int      @id @default(autoincrement())
  profileId         Int      @map("profile_id")
  questionsJson     Json?    @map("questions_json")
  userAnswersJson   Json?    @map("user_answers_json")
  gapAnalysisResult String?  @map("gap_analysis_result") @db.Text
  scoreSummary      Float?   @map("score_summary") @db.Real
  createdAt         DateTime @default(now()) @map("created_at")

  // Definisi Relasi
  profile           UserProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  // Relasi balikan ke Roadmap (1:M)
  roadmaps          LearningRoadmap[]

  @@map("assessments")
}

// 5. Model LearningRoadmap
model LearningRoadmap {
  id            Int          @id @default(autoincrement())
  profileId     Int          @map("profile_id")
  assessmentId  Int          @map("assessment_id")
  
  // Perubahan Utama: Gunakan tipe Json untuk struktur yang kompleks
  roadmapData   Json         @map("roadmap_data") 
  
  totalNodes    Int?         @map("total_nodes")
  completedNodes Int         @default(0) @map("completed_nodes")
  status        String       @default("active") // active, completed
  createdAt     DateTime     @default(now()) @map("created_at")

  profile       UserProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  assessment    Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@map("learning_roadmaps")
}

// 6. Model UserProgressJRS — Menyimpan snapshot JRS untuk grafik Impact Projection
model UserProgressJRS {
  id           Int         @id @default(autoincrement())
  profileId    Int         @map("profile_id")
  assessmentId Int         @map("assessment_id")
  jrsScore     Float       @map("jrs_score") @db.Real
  passedKUK    Int         @map("passed_kuk")
  totalKUK     Int         @map("total_kuk")
  careerName   String      @map("career_name") @db.VarChar(255)
  createdAt    DateTime    @default(now()) @map("created_at")

  profile      UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("user_progress_jrs")
}
